#!/usr/bin/env bash
set -euo pipefail

# Auto-generate example.env from .env (keys only, values stripped)
DOTFILES_DIR="$(git rev-parse --show-toplevel)"
if [[ -f "$DOTFILES_DIR/.env" ]]; then
	sed 's/=.*/=/' "$DOTFILES_DIR/.env" >|example.env
	git add example.env
fi

# Block .env from being committed (contains secrets)
if git diff --cached --name-only | grep -qx '\.env'; then
	echo "ERROR: .env contains secrets and must not be committed."
	echo "It is gitignored — if you force-added it, run: git reset HEAD .env"
	exit 1
fi

# Update Brewfile with current packages (brew + npm global)
# Excluded npm globals (installed via other channels — don't track here):
#   claude-code: native installer (curl claude.ai/install.sh)
if command -v brew &>/dev/null; then
	brew bundle dump --file=brew/Brewfile --force
	if command -v npm &>/dev/null; then
		# `|| true` so grep exiting non-zero (no non-npm globals) doesn't abort under pipefail
		npm list -g --depth=0 --parseable 2>/dev/null | tail -n +2 | xargs -I{} basename {} |
			{ grep -vE '^(npm|claude-code)$' || true; } | sort | while read -r pkg; do
			echo "npm \"$pkg\"" >>brew/Brewfile
		done
	fi
	git add brew/Brewfile
fi

# Update Skillfile with installed skills (union of ~/.agents/skills and ~/.claude/skills)
if [[ -d "$HOME/.agents/skills" || -d "$HOME/.claude/skills" ]]; then
	{
		[[ -d "$HOME/.agents/skills" ]] && ls -1 "$HOME/.agents/skills"
		[[ -d "$HOME/.claude/skills" ]] && ls -1 "$HOME/.claude/skills"
	} | sort -u >|Skillfile
	git add Skillfile
fi

# Update Claude plugin tracking: Marketplacefile + Pluginfile
if command -v claude &>/dev/null && command -v jq &>/dev/null; then
	# Marketplacefile: "<name> <owner/repo>" per line (source type is always github today)
	claude plugin marketplace list --json 2>/dev/null |
		jq -r '.[] | select(.source == "github") | "\(.name) \(.repo)"' 2>/dev/null |
		sort >|Marketplacefile || true
	[[ -s Marketplacefile ]] && git add Marketplacefile

	# Pluginfile: "<plugin>@<marketplace>" per line (consumed by `claude plugin install`)
	claude plugin list --json 2>/dev/null |
		jq -r '.[].id' 2>/dev/null | sort >|Pluginfile || true
	[[ -s Pluginfile ]] && git add Pluginfile
fi

# Detect secrets in staged files before committing (gitleaks)
if command -v gitleaks &>/dev/null; then
	if ! gitleaks protect --staged --redact --no-banner; then
		echo ""
		echo "If these are false positives, commit with --no-verify"
		exit 1
	fi
else
	echo "WARNING: gitleaks not installed — secret scan skipped. Install with: brew install gitleaks" >&2
fi
