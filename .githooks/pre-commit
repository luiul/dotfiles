#!/usr/bin/env bash
set -euo pipefail

# Auto-generate example.env from .env (keys only, values stripped)
DOTFILES_DIR="$(git rev-parse --show-toplevel)"
if [[ -f "$DOTFILES_DIR/.env" ]]; then
	sed 's/=.*/=/' "$DOTFILES_DIR/.env" >|example.env
	git add example.env
fi

# Block .env from being committed (contains secrets)
if git diff --cached --name-only | grep -qx '\.env'; then
	echo "ERROR: .env contains secrets and must not be committed."
	echo "It is gitignored — if you force-added it, run: git reset HEAD .env"
	exit 1
fi

# Update Brewfile with current packages, preserving custom entries (npm, uv)
if command -v brew &>/dev/null; then
	custom=$(grep -E '^npm ' brew/Brewfile 2>/dev/null | sort -u || true)
	brew bundle dump --file=brew/Brewfile --force
	if [[ -n "$custom" ]]; then
		echo "$custom" >>brew/Brewfile
	fi
	git add brew/Brewfile
fi

# Update Skillfile with installed skills
if [[ -d "$HOME/.agents/skills" ]]; then
	ls -1 "$HOME/.agents/skills" >|Skillfile
	git add Skillfile
fi

# Detect secrets in staged files before committing
SECRETS_PATTERN='AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36,}|gho_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{22,}|sk-[A-Za-z0-9]{20,}|xox[bpsar]-[A-Za-z0-9-]{10,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|[aA][pP][iI][_-]?[kK][eE][yY][[:space:]]*[:=][[:space:]]*[A-Za-z0-9/+=_-]{16,}|[aA][pP][iI][_-]?[sS][eE][cC][rR][eE][tT][[:space:]]*[:=][[:space:]]*[A-Za-z0-9/+=_-]{16,}|[sS][eE][cC][rR][eE][tT][_-]?[kK][eE][yY][[:space:]]*[:=][[:space:]]*[A-Za-z0-9/+=_-]{16,}'

matches=$(git diff --cached -U0 --diff-filter=ACM | grep -En -e "$SECRETS_PATTERN" 2>/dev/null || true)
if [[ -n "$matches" ]]; then
	echo "Possible secrets detected in staged files:"
	echo ""
	echo "$matches"
	echo ""
	echo "If these are false positives, commit with --no-verify"
	exit 1
fi
