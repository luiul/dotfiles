# Ignore all files ending with .zwc in all folders
# .zwc files are Zsh compiled files, which are generated to speed up the loading of Zsh scripts.
# They are typically generated after calling the `zsh` command or when Zsh scripts are sourced.
**/*.zwc
.DS_Store
# Ignore project-level Claude data (the claude/ stow package is tracked separately)
/.claude/
# Real .env contains secrets — only example.env is tracked
/.env
# Snowflake CLI runtime files
snowflake/.snowflake/logs/
snowflake/.snowflake/.cli_version.cache
# SSH — only track config; never commit keys, known_hosts, or agent state
ssh/.ssh/*
!ssh/.ssh/config
