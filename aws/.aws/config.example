# Template for ~/.aws/config. Copy to ~/.aws/config and fill in real values.
# The real config is gitignored because it contains an AWS account ID and the
# corporate SSO portal URL, which should not live in a public repo.

[profile sso-bedrock]
sso_start_url = https://YOUR_SSO_PORTAL.awsapps.com/start
sso_region = eu-west-1
sso_account_id = 000000000000
sso_role_name = bedrock-user
region = eu-west-1
