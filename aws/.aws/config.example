# Template for ~/.aws/config. Copy to ~/.aws/config and fill in real values.
# The real config is gitignored because it contains AWS account IDs and the
# corporate SSO portal URL, which should not live in a public repo.
#
# All profiles authenticate through one shared SSO session, so a single
# `aws sso login` covers them all:
#   aws sso login --profile sso-bedrock

[sso-session hfsso]
sso_start_url = https://YOUR_SSO_PORTAL.awsapps.com/start
sso_region = eu-west-1
sso_registration_scopes = sso:account:access

# Bedrock account
[profile sso-bedrock]
sso_session = hfsso
sso_account_id = 000000000000
sso_role_name = bedrock-user
region = eu-west-1

# Data / BI account: SCM analytics + datalake S3 buckets (default for data work)
[profile sso-bi]
sso_session = hfsso
sso_account_id = 000000000000
sso_role_name = developer
region = eu-west-1

[profile sso-bi-developer]
sso_session = hfsso
sso_account_id = 000000000000
sso_role_name = BIDeveloper
region = eu-west-1

[profile sso-bi-poweruser]
sso_session = hfsso
sso_account_id = 000000000000
sso_role_name = PowerUserAccess
region = eu-west-1

# IT account
[profile sso-it]
sso_session = hfsso
sso_account_id = 000000000000
sso_role_name = main-it-developer
region = eu-west-1
