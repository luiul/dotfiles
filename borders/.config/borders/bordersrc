#!/bin/bash

options=(
	# Rounded borders for a modern look
	style=round

	# Border width in pixels (adjust as needed)
	width=4.0

	# Keep HiDPI off unless you want auto scaling
	hidpi=off

	# Draw border over the window edge for a tighter look
	order=above

	# Bright magenta active border
	active_color=0xffff00ff

	# Inactive border (fully transparent)
	inactive_color=0x0044475a
)

borders "${options[@]}"

# To apply changes, restart the borders service:
# brew services restart borders
