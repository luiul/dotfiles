{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "awsAuthRefresh": "aws sso login --profile sso-bedrock",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "AskUserQuestion",
                "hooks": [{"type": "command", "command": "~/.claude/notify.sh \"Claude has a question in $(basename $PWD)\""}]
            },
            {
                "matcher": "ExitPlanMode",
                "hooks": [{"type": "command", "command": "~/.claude/notify.sh \"Plan ready for review in $(basename $PWD)\""}]
            }
        ],
        "PermissionRequest": [
            {
                "matcher": "",
                "hooks": [{"type": "command", "command": "~/.claude/notify.sh \"Permission required in $(basename $PWD)\""}]
            }
        ],
        "Stop": [
            {
                "matcher": "",
                "hooks": [{"type": "command", "command": "~/.claude/notify.sh \"Task completed in $(basename $PWD)\""}]
            }
        ]
    },
    "env": {
        "AWS_PROFILE": "sso-bedrock",
        "AWS_REGION": "eu-west-1",
        "CLAUDE_CODE_USE_BEDROCK": "1",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-6-v1",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "eu.anthropic.claude-sonnet-4-6",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "eu.anthropic.claude-haiku-4-5-20251001-v1:0"
    }
}
