{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login --profile sso-bedrock",
  "env": {
    "AWS_PROFILE": "sso-bedrock",
    "AWS_REGION": "eu-west-1",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "BASH_MAX_OUTPUT_LENGTH": "100000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "100000",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(stow:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh search:*)",
      "Bash(gh auth:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(uv run:*)",
      "Bash(uv venv:*)",
      "Bash(uv lock:*)",
      "Bash(uv sync:*)",
      "Bash(uv tree:*)",
      "Bash(uv python:*)",
      "Bash(uv version:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip show:*)",
      "Bash(uv pip freeze:*)",
      "Bash(uv pip check:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(databricks jobs:*)",
      "Bash(databricks runs:*)",
      "Bash(databricks workspace:*)",
      "Bash(databricks clusters:*)",
      "Bash(databricks fs:*)",
      "Bash(databricks secrets:*)",
      "Bash(databricks pipelines:*)",
      "Bash(databricks repos:*)",
      "Bash(databricks auth:*)",
      "Bash(ruff:*)",
      "Bash(gcloud auth:*)",
      "Bash(gcloud config:*)",
      "Bash(gcloud projects:*)",
      "Bash(gcloud iam:*)",
      "Bash(gcloud compute:*)",
      "Bash(gcloud storage:*)",
      "Bash(gcloud logging:*)",
      "Bash(cd:*)",
      "WebFetch"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Claude has a question in $(basename $PWD)\""
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Plan ready for review in $(basename $PWD)\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Claude is done in $(basename $PWD)\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Permission required in $(basename $PWD)\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true
  }
}
