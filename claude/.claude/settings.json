{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login --profile sso-bedrock",
  "env": {
    "AWS_PROFILE": "sso-bedrock",
    "AWS_REGION": "eu-west-1",
    "BASH_MAX_OUTPUT_LENGTH": "100000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(stow:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh search:*)",
      "Bash(gh auth:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(uv run:*)",
      "Bash(uv venv:*)",
      "Bash(uv lock:*)",
      "Bash(uv sync:*)",
      "Bash(uv tree:*)",
      "Bash(uv python:*)",
      "Bash(uv version:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip show:*)",
      "Bash(uv pip freeze:*)",
      "Bash(uv pip check:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(databricks jobs:*)",
      "Bash(databricks runs:*)",
      "Bash(databricks workspace:*)",
      "Bash(databricks clusters:*)",
      "Bash(databricks fs:*)",
      "Bash(databricks secrets:*)",
      "Bash(databricks pipelines:*)",
      "Bash(databricks repos:*)",
      "Bash(databricks auth:*)",
      "Bash(ruff:*)",
      "Bash(gcloud auth:*)",
      "Bash(gcloud config:*)",
      "Bash(gcloud projects:*)",
      "Bash(gcloud iam:*)",
      "Bash(gcloud compute:*)",
      "Bash(gcloud storage:*)",
      "Bash(gcloud logging:*)",
      "Bash(cd:*)",
      "WebFetch"
    ],
    "defaultMode": "auto"
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeNotifier/notify.sh\" input_needed"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeNotifier/notify.sh\" permission_request"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/plan-to-html.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeNotifier/notify.sh\" compact_complete"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeNotifier/notify.sh\" task_complete"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "skipWorkflowUsageWarning": true
}
