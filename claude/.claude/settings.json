{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login --profile sso-bedrock",
  "env": {
    "AWS_PROFILE": "sso-bedrock",
    "AWS_REGION": "eu-west-1",
    "CLAUDE_CODE_USE_BEDROCK": "1"
  },
  "attribution": {
    "commit": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Claude has a question in $(basename $PWD)\""
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Plan ready for review in $(basename $PWD)\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Permission required in $(basename $PWD)\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh \"Task completed in $(basename $PWD)\""
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(stow:*)",
      "Bash(gh:*)",
      "Bash(brew:*)",
      "Bash(ls:*)",
      "WebFetch"
    ]
  }
}
