{
  "settings": {
    "toolPrefix": "server",
    "idleTimeout": 10
  },
  "mcpServers": {
    "kb": {
      "type": "http",
      "url": "https://genai-lab-api.eu.foundations.shared.int.hellofresh.io/mcp/v2",
      "lifecycle": "lazy",
      "directTools": true
    },
    "excalidraw": {
      "type": "http",
      "url": "https://mcp.excalidraw.com",
      "lifecycle": "lazy",
      "directTools": true
    },
    "drawio": {
      "type": "http",
      "url": "https://mcp.draw.io/mcp",
      "lifecycle": "lazy",
      "directTools": true
    },
    "context-mode": {
      "command": "context-mode",
      "directTools": true
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "lifecycle": "lazy",
      "directTools": true,
      "auth": "bearer",
      "bearerTokenEnv": "SLACK_MCP_TOKEN"
    }
  }
}
