// Place your key bindings in this file to override the defaultsauto[]
[
    {
        "key": "ctrl+enter",
        "command": "-jupyter.runcurrentcell",
        "when": "editorTextFocus && isWorkspaceTrusted && jupyter.hascodecells && !editorHasSelection && !jupyter.havenativecells && !notebookEditorFocused"
    },
    {
        "key": "ctrl+enter",
        "command": "-jupyter.runByLineStop",
        "when": "notebookCellResource in 'jupyter.notebookeditor.runByLineCells'"
    },
    {
        "key": "cmd+d",
        "command": "markdown.extension.toc.addSecNumbers"
    },
    {
        "key": "f2",
        "command": "renameFile",
        "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    // Free up Alt+Cmd+T from its default (Close Other Editors)
    {
        "key": "alt+cmd+t",
        "command": "-workbench.action.closeOtherEditors"
    },
    // Terminal shortcuts: T toggle, S split, W close, R refresh
    {
        "key": "alt+cmd+t",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    {
        "key": "alt+cmd+d",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    {
        "key": "alt+cmd+w",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus"
    },
    {
        "key": "alt+cmd+r",
        "command": "macros.refreshTerminal"
    },
    // Markdown All in One — Remove default keybindings that conflict with macOS shortcuts
    {
        "key": "cmd+b",
        "command": "-markdown.extension.editing.toggleBold",
    },
    {
        "key": "cmd+m",
        "command": "-markdown.extension.editing.toggleMath",
    },
    {
        "key": "shift+alt+cmd+c",
        "command": "-copyRelativeFilePath",
        "when": "!editorFocus"
    },
    {
        "key": "shift+alt+cmd+f",
        "command": "copyRelativeFilePath",
        "when": "editorFocus"
    },
    {
        "key": "cmd+k shift+alt+cmd+c",
        "command": "-copyRelativeFilePath",
        "when": "editorFocus"
    },
    // Disable external terminal (keeps accidentally opening)
    {
        "key": "shift+cmd+c",
        "command": "-workbench.action.terminal.openNativeConsole",
        "when": "!terminalFocus"
    },
]
