{
    // === Workbench Settings ===
    "workbench.settings.useSplitJSON": true,
    "workbench.startupEditor": "none",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.settings.editor": "json",
    "workbench.tree.renderIndentGuides": "always",
    "workbench.tree.indent": 14,
    "workbench.list.openMode": "doubleClick",
    "workbench.fontAliasing": "antialiased",
    "workbench.colorCustomizations": {
        "tab.activeBorderTop": "#ff00ee",
        "notebook.focusedCellBackground": "#0099ff30",
        "editor.findMatchBackground": "#8ffa876b",
        "editor.findMatchHighlightBackground": "#ff7dbe75",
        "sqltools.currentQueryBg": "#7b798a03",
        "tree.indentGuidesStroke": "#51bdd8",
        "tree.inactiveIndentGuidesStroke": "#232a35",
        "editor.lineHighlightBackground": "#008cff28",
        "editor.lineHighlightBorder": "#9fced11f",
    },
    "workbench.tree.enableStickyScroll": true,
    "workbench.sideBar.location": "right",
    "workbench.editor.alwaysShowEditorActions": true,
    // === Editor Settings ===
    "editor.fontFamily": "'MesloLGS Nerd Font Mono', Menlo, DejaVu Sans Mono, Source Code Pro, Inconsolata, Monaco, Courier New, monospace",
    "editor.fontSize": 12,
    "editor.wordWrap": "on",
    "editor.smoothScrolling": true,
    "editor.cursorBlinking": "solid",
    "editor.guides.bracketPairs": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.minimap.autohide": "mouseover",
    "editor.minimap.renderCharacters": false,
    "editor.folding": true,
    "editor.glyphMargin": true,
    "editor.rulers": [
        120
    ],
    "editor.stickyScroll.enabled": true,
    "editor.tokenColorCustomizations": {
        "comments": "#aaaaaa",
        "textMateRules": [
            {
                "scope": "heading.1.markdown entity.name.section.markdown, heading.1.markdown punctuation.definition.heading.markdown",
                "settings": {
                    "foreground": "#e86f4f"
                }
            },
            {
                "scope": "heading.2.markdown entity.name.section.markdown, heading.2.markdown punctuation.definition.heading.markdown",
                "settings": {
                    "foreground": "#f4a361"
                }
            },
            {
                "scope": "heading.3.markdown entity.name.section.markdown, heading.3.markdown punctuation.definition.heading.markdown",
                "settings": {
                    "foreground": "#eac56a"
                }
            },
            {
                "scope": "heading.4.markdown entity.name.section.markdown, heading.4.markdown punctuation.definition.heading.markdown",
                "settings": {
                    "foreground": "#269f91"
                }
            },
            {
                "scope": "heading.5.markdown entity.name.section.markdown, heading.5.markdown punctuation.definition.heading.markdown",
                "settings": {
                    "foreground": "#5d99b0"
                }
            }
        ]
    },
    "editor.lineNumbers": "on",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    // === Editor hygiene ===
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "editor.renderWhitespace": "all",
    "editor.tabSize": 4,
    // === Format on Save (global & per-language)
    "editor.formatOnSave": true,
    // === Terminal Settings ===
    "terminal.integrated.fontFamily": "'MesloLGS Nerd Font Mono', Menlo, DejaVu Sans Mono, Source Code Pro, Inconsolata, Monaco, Courier New, monospace",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.persistentSessionScrollback": 1000,
    "terminal.integrated.lineHeight": 1.5,
    "terminal.integrated.tabs.hideCondition": "never",
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorStyleInactive": "none",
    "terminal.integrated.cursorWidth": 2,
    // === Diff Editor Settings ===
    "diffEditor.wordWrap": "inherit",
    "diffEditor.experimental.showMoves": true,
    // === Explorer Settings ===
    "explorer.sortOrder": "foldersNestsFiles",
    "explorer.confirmDragAndDrop": false,
    "explorer.compactFolders": false,
    // === Notebook Settings ===
    "notebook.insertToolbarLocation": "notebookToolbar",
    "notebook.output.textLineLimit": 40,
    "notebook.output.lineHeight": 18,
    "notebook.stickyScroll.enabled": true,
    "notebook.diff.ignoreMetadata": true,
    "notebook.cellExecutionTimeVerbosity": "verbose",
    // === Git Settings ===
    "git-graph.repository.fetchAndPrune": true,
    "git-graph.commitDetailsView.location": "Docked to Bottom",
    "git-graph.date.format": "ISO Date & Time",
    "git-graph.graph.style": "angular",
    "git-graph.maxDepthOfRepoSearch": 1,
    "git.autoStash": true,
    "git.autoRepositoryDetection": "openEditors",
    "git.openRepositoryInParentFolders": "always",
    "git.autofetch": true,
    // === GitHub Settings ===
    "githubPullRequests.remotes": [
        "origin",
        "upstream"
    ],
    "githubPullRequests.pushBranch": "always",
    "githubPullRequests.pullBranch": "never",
    "githubPullRequests.fileListLayout": "tree",
    "githubIssues.queries": [
        {
            "label": "My Issues",
            "query": "is:open assignee:${user} repo:${owner}/${repository}",
            "groupBy": [
                "milestone"
            ]
        },
        {
            "label": "Created Issues",
            "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
        },
        {
            "label": "Recent Issues",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc"
        }
    ],
    // === Language-Specific Settings ===
    "[markdown]": {
        "editor.tabSize": 4,
        "editor.defaultFormatter": "yzhang.markdown-all-in-one",
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.formatOnSave": false
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    // === Python formatter  ===
    "[python]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    //
    // Ruff
    //
    "ruff.path": [
        "${env:HOME}/.local/bin/ruff"
    ],
    "ruff.importStrategy": "fromEnvironment",
    "ruff.configuration": "${env:HOME}/.config/ruff/ruff.toml",
    //
    // Ty
    //
    "ty.path": [
        "${env:HOME}/.local/bin/ty"
    ],
    "ty.importStrategy": "fromEnvironment",
    "ty.interpreter": "${workspaceFolder}/.venv/bin/python",
    // Jupyter Notebooks formatter
    "notebook.formatOnSave.enabled": true,
    "notebook.codeActionsOnSave": {
        "notebook.source.fixAll": "explicit"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.formatOnSave": true
    },
    // === Terraform / OpenTofu ===
    // HashiCorp extension provides the language server (fmt, validate, completion,
    // hover, go-to-definition). We use OpenTofu (`tofu`) rather than the `terraform`
    // binary, so point the language server at it; fmt-on-save runs `tofu fmt`.
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": true,
        "editor.tabSize": 2
    },
    "[terraform-vars]": {
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": true,
        "editor.tabSize": 2
    },
    "terraform.languageServer.enable": true,
    "terraform.languageServer.path": "/opt/homebrew/bin/tofu",
    "terraform.codelens.referenceCount": true,
    "[jinja-yaml]": {
        "editor.formatOnSave": true
    },
    // === Python Analysis ===
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.autoFormatStrings": true,
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.exclude": [
        "**/venv/**",
        "**/.venv/**",
        "**/.vscode/**",
        "**/.git/**",
        "**/__pycache__/**",
        "**/.mypy_cache/**",
        "**/.pytest_cache/**",
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/site-packages",
        "**/.*",
    ],
    // === Python Virtual Environment ===
    "python.envFile": "${workspaceFolder}/.env",
    "python.terminal.activateEnvironment": false,
    "python.terminal.activateEnvInCurrentTerminal": true,
    // === Python Testing ===
    "python.testing.pytestEnabled": true,
    "python.testing.cwd": "${workspaceFolder}/tests",
    // === Miscellaneous ===
    "update.mode": "manual",
    "extensions.autoUpdate": true,
    "extensions.autoCheckUpdates": true,
    "telemetry.telemetryLevel": "off",
    "redhat.telemetry.enabled": false,
    "window.openFilesInNewWindow": "on",
    // === Files/Housekeeping ===
    "files.autoSave": "onWindowChange",
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/.ipynb_checkpoints": true,
        "**/*.egg-info": true,
        "**/.DS_Store": true
    },
    "search.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/.ipynb_checkpoints": true,
        "**/*.egg-info": true,
        "**/.venv": true,
        "**/venv": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.git": true
    },
    "files.watcherExclude": {
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/.mypy_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/.ipynb_checkpoints/**": true,
        "**/.venv/**": true,
        "**/venv/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/.git/objects/**": true
    },
    // === Debug/Other ===
    "debug.toolBarLocation": "docked",
    "yaml.schemas": {
        "file:///Users/luis.aceituno/.vscode/extensions/docsmsft.docs-yaml-1.0.6/dist/toc.schema.json": "/toc\\.yml/i"
    },
    "workbench.colorTheme": "Monokai",
    "python.languageServer": "Pylance",
    "editor.inlayHints.enabled": "offUnlessPressed",
    "jupyter.askForKernelRestart": false,
    // === dbt & SQL ===
    "files.associations": {
        "*.sql": "jinja-sql"
    },
    "[jinja-sql]": {
        "editor.defaultFormatter": "innoverio.vscode-dbt-power-user",
        "editor.formatOnSave": true
    },
    "dbt.sqlFmtAdditionalParams": [
        "--line-length",
        "120"
    ],
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": ".*\\.sql(\\.jinja)?$",
                "notMatch": ".*/dbt/.*",
                "isAsync": false,
                "cmd": "echo 'Running sqlfmt on: ${file}' && $HOME/.local/bin/sqlfmt --line-length 120 '${file}'"
            },
            {
                "match": ".*\\.tf$",
                "isAsync": true,
                "cmd": "d=$(dirname '${file}'); cfg=$(cd \"$d\" && git rev-parse --show-toplevel 2>/dev/null); if [ -n \"$cfg\" ] && [ -f \"$cfg/.github/linters/.tflint.hcl\" ]; then /opt/homebrew/bin/tflint --chdir=\"$d\" --config=\"$cfg/.github/linters/.tflint.hcl\"; else /opt/homebrew/bin/tflint --chdir=\"$d\"; fi"
            }
        ]
    },
    "dbt.sqlFmtPath": "${env:HOME}/.local/bin/sqlfmt",
    // === UI & Misc ===
    "workbench.productIconTheme": "fluent-icons",
    "makefile.configureOnOpen": true,
    "git.blame.editorDecoration.enabled": true,
    "macros": {
        "refreshTerminal": [
            "workbench.action.terminal.kill",
            "workbench.action.terminal.new"
        ]
    },
    "diffEditor.ignoreTrimWhitespace": true,
    "dbt.enableNewLineagePanel": true,
    //
    // Copilot and Chat
    //
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": true
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    // === Extensions/Tools ===
    "docker.extension.enableComposeLanguageServer": false,
    "parquet-viewer.format": "csv",
    "chat.mcp.autostart": "newAndOutdated",
    "aws.cloudformation.telemetry.enabled": false,
    "aws.telemetry": false,
    "git.blame.statusBarItem.enabled": true,
    "chat.viewSessions.orientation": "stacked",
    "terminal.external.osxExec": "Ghostty.app",
    // Point dbt at the standard profiles location for any workspace that doesn't override it.
    "terminal.integrated.env.osx": {
        "DBT_PROFILES_DIR": "${env:HOME}/.dbt"
    },
    "claudeCode.preferredLocation": "panel",
    "python.terminal.useEnvFile": false,
    "workbench.activityBar.location": "top",
    "window.commandCenter": false,
    "markdown-preview-github-styles.colorTheme": "light",
    "terminal.integrated.tabs.enabled": false,
}
